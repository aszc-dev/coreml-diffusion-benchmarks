.venv/
.env
.worktrees/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
results/raw/*.plist
results/raw/*.txt
assets/shared_input/*.npz

# Converted model artifacts are large and regenerated by the conversion drivers;
# keep only the small per-build conversion-timing JSON under artifacts/ (R9).
*.mlpackage/
*.mlmodelc/

*.log

# Per-user TUI state (run plan saved by `sdbench config`).
.sdbench/

# Internal design notes, not for the public repo
tui.md

# Run output is regenerated every benchmark; never source.
results/data/*.jsonl
results/data/*.json
results/data/environments/
results/tables/*.md

# Local backups of .env (e.g. when reinstalling tooling).
.env.bak
*.env.bak
